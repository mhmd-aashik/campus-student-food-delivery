                    "login"
                  ]
                }
              },
              "response": []
            },
            {
              "name": "3. Refresh JWT Token",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "const response = pm.response.json();",
                      "if (response.accessToken) {",
                      "    pm.environment.set(\"driver_jwt_token\", response.accessToken);",
                      "}",
                      "if (response.refreshToken) {",
                      "    pm.environment.set(\"driver_refresh_token\", response.refreshToken);",
                      "}"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"refreshToken\": \"{{driver_refresh_token}}\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/auth/refresh",
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "path": [
                    "auth",
                    "refresh"
                  ]
                }
              },
              "response": []
            },
